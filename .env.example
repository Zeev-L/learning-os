# העתק ל-.env ומלא את המפתח כדי לקבל תקצירי עברית אוטומטיים (אופציונלי).
# בלי מפתח — המערכת עדיין עובדת ומשתמשת בתקציר של ה-feed.
# אל תעשה commit ל-.env! הוא כבר ב-.gitignore.
ANTHROPIC_API_KEY=
# מודל לתקצור (ברירת מחדל: claude-sonnet-5)
LO_MODEL=claude-sonnet-5

# ---- ניוזלטרים מהמייל (אופציונלי) ----
# תיבה אישית ב-Gmail. דורש: 2FA פעיל → הפעלת IMAP → יצירת App Password.
# אל תדביק את הסיסמה בצ'אט — רק כאן בקובץ .env המקומי (מוגן ב-gitignore).
IMAP_USER=zeev370@gmail.com
IMAP_APP_PASSWORD=
# התווית ב-Gmail שאליה מנותבים הניוזלטרים (ברירת מחדל: Learning)
LO_MAIL_LABEL=Learning
